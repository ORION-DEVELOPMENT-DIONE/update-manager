---
- name: Orion Device Auto-Provisioning
  hosts: localhost
  connection: local
  become: yes
  
  vars:
    device_hostname: "{{ ansible_hostname }}"
    #tailscale_auth_key: "{{ lookup('env', 'TAILSCALE_AUTH_KEY') }}"  # Set via env or hardcode
    
  pre_tasks:

    - name: Fix Jinja2 compatibility issue
      pip:
        name: jinja2
        version: "3.1.5"
        executable: pip3
        extra_args: --upgrade
      ignore_errors: yes
    - name: Update apt cache
      apt:
        update_cache: yes
        cache_valid_time: 3600
      
    - name: Install required packages
      apt:
        name:
          - git
          - python3
          - python3-pip
          - curl
          - jq
        state: present

  roles:
    - network-config
    - tailscale-auth
    - tailscale
    - screen-manager
    - auto-update

  post_tasks:
    - name: Log provisioning completion
      shell: |
        echo "$(date): Provisioning completed successfully" >> /var/log/orion-provisioning.log
